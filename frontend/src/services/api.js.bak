// Configuração da API - Becker V8
const API_PORT = 6778;

// Força HTTPS explicitamente usando o hostname atual
const BASE_URL = `https://${window.location.hostname}:${API_PORT}/api`;

const getToken = () => localStorage.getItem('becker_token');

export const api = {
  get: async (endpoint) => {
    try {
      const res = await fetch(`${BASE_URL}${endpoint}`, { 
        headers: { 'Authorization': `Bearer ${getToken()}` } 
      });
      if (!res.ok) {
        try { const err = await res.json(); console.error(err); } catch(e){}
        return null;
      }
      return await res.json();
    } catch (e) { 
      console.error("API GET Error:", e);
      return null; 
    }
  },

  post: async (endpoint, body) => {
    try {
      const res = await fetch(`${BASE_URL}${endpoint}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
        body: JSON.stringify(body)
      });
      
      const data = await res.json();
      return data;
    } catch (e) { 
      console.error("API POST Error:", e);
      return { success: false, error: "Erro de Conexão Segura (HTTPS 6778)" }; 
    }
  }
};
