{% set server_names = ([config.domains.public_domain] + config.domains.internal_domains) | unique | join(' ') %}
{% set effective_https = config.domains.enable_https and config.domains.ssl_certificate_path and config.domains.ssl_certificate_key_path %}
{% if effective_https and config.domains.https_redirect_http %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ server_names }};

    return 301 https://$host$request_uri;
}
{% endif %}

server {
{% if effective_https %}
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
{% else %}
    listen 80;
    listen [::]:80;
{% endif %}
    server_name {{ server_names }};
    client_max_body_size 64m;
{% if effective_https %}
    ssl_certificate {{ config.domains.ssl_certificate_path }};
    ssl_certificate_key {{ config.domains.ssl_certificate_key_path }};
{% endif %}

    location / {
        root {{ config.stack.project_root }}/frontend/dist;
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:{{ config.stack.backend_port }}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/dns/ {
        proxy_pass http://127.0.0.1:{{ config.stack.backend_proxy_port }}/api/dns/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
