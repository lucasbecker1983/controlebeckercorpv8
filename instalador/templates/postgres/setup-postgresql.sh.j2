#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SQL_FILE="${SCRIPT_DIR}/postgres-init.sql"

systemctl enable postgresql
systemctl start postgresql

sudo -u postgres psql -f "${SQL_FILE}"

if ! sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname='{{ config.database.database }}'" | grep -q 1; then
  sudo -u postgres createdb -O "{{ config.database.user }}" "{{ config.database.database }}"
fi

echo "PostgreSQL preparado para o banco {{ config.database.database }}"
